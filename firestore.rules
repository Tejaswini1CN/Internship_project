rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() /* no email verification in standard guest auth right now, skipping for this prototype */; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Models
    function isValidEvent(data) {
       return data.keys().hasAll(['id', 'title', 'description', 'location', 'startTime', 'endTime'])
           && data.title is string && data.title.size() <= 500
           && data.description is string && data.description.size() <= 2000
           && data.location is string && data.location.size() <= 500
           && data.startTime is string && data.startTime.size() <= 100
           && data.endTime is string && data.endTime.size() <= 100
           // isLive and isFavorite are local states, might not sync them or we will.
           // Admin only check can be added here
           ;
    }

    function isValidReport(data) {
       return data.keys().hasAll(['id', 'reportType', 'name', 'description', 'location', 'dateTime', 'contactNumber', 'status', 'ownerId'])
           && data.reportType is string && data.reportType.size() <= 50
           && data.name is string && data.name.size() <= 200
           && data.description is string && data.description.size() <= 2000
           && data.location is string && data.location.size() <= 500
           && data.dateTime is string && data.dateTime.size() <= 100
           && data.contactNumber is string && data.contactNumber.size() <= 50
           && data.status is string && data.status.size() <= 50
           && data.ownerId == request.auth.uid;
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(eventId) && isValidEvent(incoming());
      // Only fields we care about
      allow update: if isSignedIn() && isValidId(eventId) && isValidEvent(incoming()) && (
          // In a real app we'd restrict update to admins
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'location', 'startTime', 'endTime', 'isLive', 'category', 'updatedAt'])
      );
      allow delete: if false;
    }

    match /reports/{reportId} {
      allow read: if true; // Publicly readable for the community help desk
      allow create: if isSignedIn() && isValidId(reportId) && isValidReport(incoming()) && data.keys().size() <= 15;
      allow update: if isSignedIn() && isValidId(reportId) && isValidReport(incoming()) && (
         (existing().ownerId == request.auth.uid && incoming().ownerId == existing().ownerId && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'description', 'contactNumber', 'name', 'age', 'location', 'imageUri', 'updatedAt']))
      );
      allow delete: if existing().ownerId == request.auth.uid;
    }
  }
}
